---

<footer class="footer">
  <!-- Top accent line -->
  <div class="footer-accent-line"></div>

  <div class="container mx-auto px-4 pt-8 pb-4">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo-link">
          <span class="footer-logo-text">AT</span>
          <span class="footer-logo-separator">|</span>
          <span class="footer-logo-text footer-logo-secondary">Blog</span>
        </a>
        <p class="footer-desc">
          ATBSPB 的个人博客，记录开发实践与技术笔记。<br>代码、项目与技术探索。
        </p>
        <!-- Social -->
        <div class="footer-social">
          {socialLinks.map(({ href, label, icon }) => (
            <a href={href} class="footer-social-btn" aria-label={label}>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

    </div>

    <!-- Bottom -->
    <div class="footer-bottom">
      <div class="footer-bottom-line"></div>
      <div class="footer-bottom-content">
        <p class="footer-copyright">
          &copy; {new Date().getFullYear()} ATBSPB. All rights reserved.
        </p>
        <div class="footer-bottom-divider"></div>
        <p class="footer-powered">
          Crafted with <span class="footer-heart">&hearts;</span> powered by <span class="footer-powered-highlight">Astro</span>
        </p>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer {
    background: var(--color-secondary);
    position: relative;
  }
  .footer-accent-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-accent-gold), transparent);
    opacity: 0.3;
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Brand */
  .footer-logo-link {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    margin-bottom: 0.5rem;
    transition: opacity 0.3s ease;
  }
  .footer-logo-link:hover { opacity: 0.8; }
  .footer-logo-text {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--color-accent-gold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .footer-logo-secondary {
    font-size: 0.875rem;
    font-weight: 200;
    color: var(--color-text-muted);
  }
  .footer-logo-separator {
    font-family: 'Josefin Sans', sans-serif;
    font-size: 1.125rem;
    font-weight: 100;
    color: rgba(192, 160, 98, 0.35);
    margin: 0 0.375rem;
  }
  .footer-desc {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  /* Social */
  .footer-social {
    display: flex;
    gap: 0.75rem;
  }
  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid rgba(192, 160, 98, 0.2);
    border-radius: 6px;
    color: var(--color-text-muted);
    transition: all 0.3s ease;
  }
  .footer-social-btn:hover {
    color: var(--color-accent-gold);
    border-color: var(--color-accent-gold);
    background: rgba(192, 160, 98, 0.05);
    transform: translateY(-2px);
  }

  /* Bottom */
  .footer-bottom {
    margin-top: 1.5rem;
    padding-top: 0;
  }
  .footer-bottom-line {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(192, 160, 98, 0.15) 20%,
      rgba(192, 160, 98, 0.3) 50%,
      rgba(192, 160, 98, 0.15) 80%,
      transparent
    );
    margin-bottom: 1.25rem;
  }
  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-copyright {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }
  .footer-copyright:hover {
    opacity: 0.9;
  }
  .footer-bottom-divider {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(192, 160, 98, 0.3);
  }
  .footer-powered {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }
  .footer-powered:hover {
    opacity: 0.8;
  }
  .footer-heart {
    color: #e74c3c;
    display: inline-block;
    animation: heartbeat 1.5s ease-in-out infinite;
    font-size: 0.75rem;
  }
  .footer-powered-highlight {
    color: var(--color-accent-gold);
    font-weight: 500;
    transition: text-shadow 0.3s ease;
  }
  .footer-powered:hover .footer-powered-highlight {
    text-shadow: 0 0 8px rgba(192, 160, 98, 0.3);
  }
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
  @media (max-width: 640px) {
    .footer-bottom-content {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
    .footer-bottom-divider {
      display: none;
    }
  }
</style>
