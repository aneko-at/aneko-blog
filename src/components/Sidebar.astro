        </svg>
        标签
      </h3>
      <div class="flex flex-wrap gap-2">
        {tags.map(([tag, count]) => (
          <a
            href={`/blog?tag=${encodeURIComponent(tag)}`}
            data-tag-link={tag}
            class="sidebar-tag text-xs px-2.5 py-1 border border-text-muted/20 text-text-muted hover:border-accent-gold/50 hover:text-accent-gold transition-all duration-300"
