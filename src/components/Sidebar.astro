</aside>

<script>
  function highlightActiveTag() {
    const params = new URLSearchParams(window.location.search);
    const tag = params.get('tag') || '';
    document.querySelectorAll('[data-tag-link]').forEach((el) => {
      const link = el as HTMLElement;
      const isActive = link.dataset.tagLink === tag;
      link.classList.toggle('border-accent-gold', isActive);
      link.classList.toggle('text-accent-gold', isActive);
      link.classList.toggle('bg-accent-gold/10', isActive);
      link.classList.toggle('border-text-muted/20', !isActive);
      link.classList.toggle('text-text-muted', !isActive);
    });
  }

  highlightActiveTag();
  document.addEventListener('astro:page-load', highlightActiveTag);
</script>
