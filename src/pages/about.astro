---

<BaseLayout title="关于 - aneko">
  <Header />

  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-primary">
    <div class="container mx-auto px-4">
      <div class="text-center reveal">
        <p class="section-subtitle">About</p>
        <h1 class="text-5xl md:text-6xl font-heading font-bold text-text mb-4">关于我</h1>
        <div class="divider-animated mx-auto"></div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="py-20 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="reveal-left">
        <h2 class="section-title">简介</h2>
        <p class="section-subtitle">about</p>
          <div class="divider-animated mb-8"></div>
          <p class="text-text-muted leading-relaxed mb-6">
            我是 aneko，独立开发者，喜欢折腾各种技术项目。
          </p>
          <p class="text-text-muted leading-relaxed mb-6">
            这个博客是我记录开发经验和技术笔记的地方。
          </p>
          <p class="text-text-muted leading-relaxed">
            内容涵盖项目实践、技术探索和工具推荐。
          </p>
        </div>

        <div class="reveal-right reveal-delay-2">
          <div class="relative">
            <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-accent-gold"></div>
            <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-accent-gold"></div>
            <div class="img-hover-zoom">
              <img
                src="/images/A2.jpg"
                alt="aneko"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-primary">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 reveal">
        <h2 class="section-title">理念</h2>
        <p class="section-subtitle">values</p>
        <div class="divider-animated mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map(({ svg, title, desc }, i) => (
          <div class={`card card-border-animated p-8 text-center reveal reveal-delay-${i + 1}`}>
            <div class="w-14 h-14 mx-auto mb-6 rounded-xl bg-accent-gold/10 border border-accent-gold/20 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-accent-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={svg} />
            </div>
            <h3 class="text-xl font-heading font-semibold text-text mb-4">{title}</h3>
            <p class="text-text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-20 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto text-center reveal-scale">
        <h2 class="section-title">联系我</h2>
        <p class="section-subtitle">contact</p>
        <div class="divider-animated mx-auto mb-8"></div>
        <p class="text-text-muted mb-8">
          如有问题或合作意向，欢迎通过以下方式联系。
        </p>
        <div class="flex flex-wrap justify-center gap-10">
          {contacts.map(({ label, value, href, svg }, i) => (
            <a href={href} target="_blank" rel="noopener noreferrer" class={`group flex flex-col items-center gap-3 reveal reveal-delay-${i + 1}`}>
              <div class="w-12 h-12 rounded-xl bg-accent-gold/10 flex items-center justify-center group-hover:bg-accent-gold/20 group-hover:scale-110 transition-all duration-300">
                <svg class="w-5 h-5 text-accent-gold" fill="currentColor" viewBox="0 0 24 24" set:html={svg} />
              </div>
              <p class="text-sm font-bold text-text uppercase tracking-wider group-hover:text-accent-gold transition-colors">{label}</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
