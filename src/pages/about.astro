---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import GithubCard from '../components/GithubCard.astro';
---

<BaseLayout title="关于 - aneko">
  <Header />

  <!-- Page Header -->
  <section class="pt-32 pb-16 bg-primary">
    <div class="container mx-auto px-4">
      <div class="text-center reveal">
        <p class="section-subtitle">About</p>
        <h1 class="text-5xl md:text-6xl font-heading font-bold text-text mb-4">关于我</h1>
        <div class="divider-animated mx-auto"></div>
      </div>
    </div>
  </section>

  <!-- Brand Story -->
  <section class="py-20 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="reveal-left">
        <h2 class="section-title">简介</h2>
        <p class="section-subtitle">about</p>
          <div class="divider-animated mb-8"></div>
          <p class="text-text-muted leading-relaxed mb-6">
            这是 aneko 的个人博客站点。
          </p>
          <div class="mb-6">
            <GithubCard repo="At-aneko/aneko-blog" />
          </div>
          <p class="text-text-muted leading-relaxed mb-4">
            <span class="font-semibold text-text">aneko 个人主页：</span>
            <a href="https://www.aneko.ink" target="_blank" rel="noopener noreferrer" class="text-accent-gold hover:underline">Aneko HomePage</a>
          </p>
          <p class="text-text-muted leading-relaxed">
            <span class="font-semibold text-text">本网站所用图片来源：</span>
            <a href="https://photo.aneko.ink" target="_blank" rel="noopener noreferrer" class="text-accent-gold hover:underline">Aneko - Photo</a>
          </p>
        </div>

        <div class="reveal-right reveal-delay-2">
          <div class="relative">
            <div class="absolute -top-4 -left-4 w-24 h-24 border-t-2 border-l-2 border-accent-gold"></div>
            <div class="absolute -bottom-4 -right-4 w-24 h-24 border-b-2 border-r-2 border-accent-gold"></div>
            <div class="img-hover-zoom">
              <img
                src="/images/A2.jpg"
                alt="aneko"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
