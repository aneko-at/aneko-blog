---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getPublishedPosts } from '../utils/posts';

const allPosts = await getPublishedPosts();

// Group by year
const postsByYear = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = post.data.pubDate.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}

const years = Array.from(postsByYear.keys()).sort((a, b) => b - a);
const totalPosts = allPosts.length;
const totalTags = new Set(allPosts.flatMap(p => p.data.tags)).size;
---

<BaseLayout title="归档 - ATBSPB | Blog">
  <Header />

  <!-- Archive Header -->
  <section class="pt-32 pb-16 bg-primary">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center reveal">
        <p class="section-subtitle">Archive</p>
        <h1 class="section-title">文章归档</h1>
        <div class="divider-animated mx-auto mb-8"></div>
        <p class="text-text-muted max-w-2xl mx-auto">
          共收录 <span class="text-accent-gold font-semibold">{totalPosts}</span> 篇文章，
          <span class="text-accent-gold font-semibold">{totalTags}</span> 个标签
        </p>
      </div>
    </div>
  </section>

  <!-- Archive Timeline -->
  <section class="py-20 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        {years.map((year, yearIdx) => (
          <div class={`mb-16 reveal reveal-delay-${Math.min(yearIdx + 1, 4)}`}>
            <!-- Year Header -->
            <div class="flex items-center gap-4 mb-8">
              <h2 class="text-4xl font-heading font-bold text-accent-gold">{year}</h2>
              <span class="text-sm text-text-muted font-body">
                {postsByYear.get(year)!.length} 篇文章
              </span>
              <div class="flex-1 h-px bg-accent-gold/20"></div>
            </div>

            <!-- Posts Timeline -->
            <div class="relative pl-8 border-l border-accent-gold/20">
              {postsByYear.get(year)!.map((post, i) => {
                const date = post.data.pubDate;
                const month = (date.getMonth() + 1).toString().padStart(2, '0');
                const day = date.getDate().toString().padStart(2, '0');

                return (
                  <div class="relative mb-8 last:mb-0 group">
                    <!-- Timeline dot -->
                    <div class="absolute -left-[calc(2rem+5px)] top-1 w-2.5 h-2.5 rounded-full bg-accent-gold/40 border-2 border-accent-gold group-hover:bg-accent-gold group-hover:scale-125 transition-all duration-300"></div>

                    <!-- Post Card -->
                    <a href={`/blog/${post.id}`} class="block p-5 bg-primary border border-text-muted/10 hover:border-accent-gold/30 transition-all duration-300 group-hover:translate-x-2">
                      <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-3 mb-2">
                            {post.data.tags.length > 0 && (
                              <div class="flex gap-1.5">
                                {post.data.tags.slice(0, 3).map(tag => (
                                  <span class="text-xs text-text-muted/60">#{tag}</span>
                                ))}
                              </div>
                            )}
                          </div>
                          <h3 class="text-lg font-heading font-semibold text-text group-hover:text-accent-gold transition-colors duration-300 truncate">
                            {post.data.title}
                          </h3>
                          <p class="text-sm text-text-muted mt-1 line-clamp-2">{post.data.description}</p>
                        </div>
                        <div class="flex-shrink-0 text-right">
                          <span class="text-sm font-body text-text-muted">{month}-{day}</span>
                        </div>
                      </div>
                    </a>
                  </div>
                );
              })}
            </div>
          </div>
        ))}

        {allPosts.length === 0 && (
          <div class="text-center py-20">
            <p class="text-text-muted text-lg">暂无文章</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
