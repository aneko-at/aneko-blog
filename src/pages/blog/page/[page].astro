---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Sidebar from '../../../components/Sidebar.astro';
import Pagination from '../../../components/Pagination.astro';
import { getPublishedPosts } from '../../../utils/posts';

const POSTS_PER_PAGE = 6;

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 6;
  const allPosts = await getPublishedPosts();

  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
  const paths = [];

  for (let i = 2; i <= totalPages; i++) {
    paths.push({
      params: { page: i.toString() },
      props: { currentPage: i },
    });
  }

  return paths;
}

const { currentPage } = Astro.props;

const allPosts = await getPublishedPosts();

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const start = (currentPage - 1) * POSTS_PER_PAGE;
const posts = allPosts.slice(start, start + POSTS_PER_PAGE);
---

<BaseLayout title={`文章 - 第${currentPage}页 - aneko | Blog`}>
  <Header />

  <!-- Blog Header -->
  <section class="pt-32 pb-16 bg-primary">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between">
          <div class="reveal">
            <p class="section-subtitle">Blog</p>
            <h1 class="section-title">文章列表</h1>
            <div class="divider-animated mb-4"></div>
            <p class="text-text-muted">第 {currentPage} 页 / 共 {totalPages} 页</p>
          </div>
          <button
            data-search-trigger
            class="hidden md:flex items-center gap-2 px-4 py-2.5 bg-secondary border border-text-muted/20 hover:border-accent-gold/50 text-text-muted hover:text-accent-gold transition-all duration-300 cursor-pointer"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <span class="text-sm">搜索文章</span>
            <kbd class="text-xs text-text-muted/30 border border-text-muted/20 px-1.5 py-0.5 ml-2">⌘K</kbd>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="py-12 bg-secondary">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8">
        <!-- Main Content -->
        <div class="flex-1">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {posts.map((post, i) => (
              <div class={`reveal reveal-delay-${Math.min(i + 1, 4)}`}>
                <ArticleCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate.toISOString().split('T')[0]}
                  slug={post.id}
                  heroImage={post.data.heroImage}
                  tags={post.data.tags}
                />
              </div>
            ))}
          </div>

          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            basePath="/blog"
          />
        </div>

        <!-- Sidebar -->
        <Sidebar />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
